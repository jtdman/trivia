      "name": "Fetch Page (with retry)",
      "retryOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const cheerio = require('cheerio');\nconst html = $json.data;\n\nif (typeof html !== 'string') {\n  return [{ \n    json: { \n      error: \"Invalid HTML content\", \n      url: $json.url || 'unknown',\n      type: typeof html \n    } \n  }];\n}\n\ntry {\n  const $ = cheerio.load(html);\n  \n  // Extract venue info\n  const venueTitle = $('.venue-title').text().trim();\n  const venueAddress = $('.venue-address').text().trim().replace(/\\s\\s+/g, ' ');\n  \n  const venueLinks = {\n    website: $('.venue-links a[href^=\"http\"]').first().attr('href') || null,\n    social: [],\n  };\n  \n  $('.venue-links a[href*=\"facebook\"], .venue-links a[href*=\"instagram\"], .venue-links a[href*=\"twitter\"]').each((_, el) => {\n    venueLinks.social.push($(el).attr('href'));\n  });\n  venueLinks.social = [...new Set(venueLinks.social)];\n  \n  // Extract shows\n  const shows = [];\n  const upcomingShowsHeader = $('h3').filter(function () {\n    return $(this).text().trim().toLowerCase() === 'upcoming shows';\n  });\n  \n  if (upcomingShowsHeader.length > 0) {\n    const showsContainer = upcomingShowsHeader.parent();\n    showsContainer.find('.show-post').each((_, el) => {\n      const showElement = $(el);\n      const showListTimeElement = showElement.find('.md-col-1.show-list-time');\n      if (showListTimeElement.length === 0) return;\n      \n      const gameLogoSrc = showListTimeElement.find('img.game-logo').attr('src');\n      let game = 'Unknown Game';\n      if (gameLogoSrc) {\n        const filename = gameLogoSrc.split('/').pop();\n        game = filename.replace(/\\.(png|jpg|jpeg|gif|svg)$/i, '')\n                       .replace(/-/g, ' ')\n                       .replace(/\\b\\w/g, l => l.toUpperCase());\n      }\n      \n      const dateTimeText = showListTimeElement.clone().children('img').remove().end().text().trim();\n      let date = '', time = '';\n      if (dateTimeText.includes('@')) {\n        [date, time] = dateTimeText.split('@').map(part => part.trim());\n      } else {\n        date = dateTimeText;\n      }\n      \n      if (date && time) {\n        shows.push({ date, time, game });\n      }\n    });\n  }\n  \n  // Return only essential data - no raw HTML\n  return {\n    json: {\n      venueInfo: {\n        url: $json.url,\n        venueTitle,\n        venueAddress, \n        venueLinks,\n        shows,\n        scrapedAt: new Date().toISOString()\n      }\n    }\n  };\n  \n} catch (error) {\n  return [{\n    json: {\n      error: error.message,\n      url: $json.url || 'unknown',\n      scrapedAt: new Date().toISOString()\n    }\n  }];\n}"
      },
