{
  "name": "trivia-backend",
  "version": "1.0.0",
  "description": "Data processing and management for trivia venue database",
  "type": "module",
  "scripts": {
    "import-venues": "tsx supabase/scripts/import-venues.ts",
    "import-venues-enhanced": "tsx supabase/scripts/import-venues-enhanced.ts",
    "import-nerdytalk": "tsx providers/nerdytalk/import-nerdytalk.ts",
    "import-nerdytalk-corrected": "tsx providers/nerdytalk/import-nerdytalk-corrected.ts",
    "import-brainblast": "tsx providers/brainblast-trivia/import-brainblast.ts",
    "scrape-nerdytalk-city-aware": "node providers/nerdytalk/scrape-nerdytalk-city-aware.js",
    "scrape-brainblast": "node providers/brainblast-trivia/scraper.cjs",
    "validate-places": "tsx supabase/scripts/validate-places.ts",
    "process-photos": "tsx supabase/scripts/process-photos.ts",
    "migrate": "supabase db reset",
