    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}