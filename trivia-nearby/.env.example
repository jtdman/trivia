# Copy to .env.local and fill in real values.
# These are public — they ship to the browser bundle. RLS (and the
# Google API key restriction) enforces access control.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Restrict this key by HTTP referrer in the Google Cloud console so it
# can only be used from trivianearby.com (and localhost in dev).
VITE_GOOGLE_PLACES_API_KEY=your-google-places-api-key
